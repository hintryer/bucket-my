{
    "version": "149.0.7827.201",
    "description": "Automatically fetch Google Chrome offline installer using GitHub Actions",
    "homepage": "https://github.com/Bush2021/chrome_installer",
    "license": "MIT",
    "depends": "chrome-plus",
    "notes": "This package acts as a binary provider. It downloads and injects the official Google Chrome binaries directly into the 'rojem/chrome-plus' installation directory. It strictly requires 'chrome-plus' to be installed first.",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Bush2021/chrome_installer/releases/download/149.0.7827.201/x64_149.0.7827.201_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "0d76e4e0b953baa6dba3d87112c81456ec71b868ae02358659268d94af51e626"
        },
        "32bit": {
            "url": "https://github.com/Bush2021/chrome_installer/releases/download/149.0.7827.201/x86_149.0.7827.201_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "90fd7ff7b3b46c01fb44a08f9838497db430dd8c552e5b1cf3431098dead8e6b"
        },
        "arm64": {
            "url": "https://github.com/Bush2021/chrome_installer/releases/download/149.0.7827.201/arm64_149.0.7827.201_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "1fe1e667c06fbd73762f21ff3825d8a3271d5abdad9a3b69ab81dfa55985e42b"
        }
    },
    "bin": "Chrome-bin/chrome.exe",
    "shortcuts": [
        [
            "Chrome-bin/Chrome.exe",
            "Google Chrome"
        ]
    ],
    "persist": [
        "/Data",
        "/Cache"
    ],
    "post_install": [
        "if (-not (Test-Path \"$env:SCOOP\\apps\\chrome-plus\\current\")) { scoop install chrome-plus }",
        "New-Item -ItemType Directory -Force -Path \"$dir\\Data\" | Out-Null",
        "New-Item -ItemType Directory -Force -Path \"$dir\\Cache\" | Out-Null",
        "if (Test-Path \"$env:SCOOP\\apps\\chrome-plus\\current\\version.dll\") { Copy-Item -Path \"$env:SCOOP\\apps\\chrome-plus\\current\\version.dll\" -Destination \"$dir\\Chrome-bin\\\" -Force }",
        "if (Test-Path \"$env:SCOOP\\apps\\chrome-plus\\current\\chrome++.ini\") { Copy-Item -Path \"$env:SCOOP\\apps\\chrome-plus\\current\\chrome++.ini\" -Destination \"$dir\\Chrome-bin\\\" -Force }"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Bush2021/chrome_installer/releases/download/$version/x64_$version_chrome_installer_uncompressed.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://github.com/Bush2021/chrome_installer/releases/download/$version/x86_$version_chrome_installer_uncompressed.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/Bush2021/chrome_installer/releases/download/$version/arm64_$version_chrome_installer_uncompressed.exe#/dl.7z"
            }
        }
    }
}
